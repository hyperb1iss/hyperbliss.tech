{
  "name": "hyperbliss.tech",
  "version": "2.0.0",
  "description": "Stefanie's Personal Website",
  "author": "Stefanie Jane <stef@hyperbliss.tech>",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "prepare": "panda",
    "dev": "next dev",
    "build": "panda && next build",
    "start": "next start",
    "lint": "biome check . && prettier --check '**/*.{md,yml,yaml}'",
    "lint:all": "biome check --write --unsafe . && prettier --write '**/*.{md,yml,yaml}'",
    "lint:fix": "biome check --write . && prettier --write '**/*.{md,yml,yaml}'",
    "format": "biome format --write && prettier --write '**/*.{md,yml,yaml}'",
    "format:check": "biome format && prettier --check '**/*.{md,yml,yaml}'",
    "format:md": "prettier --write '**/*.md'",
    "format:yaml": "prettier --write '**/*.{yml,yaml}'",
    "check": "biome check && prettier --check '**/*.{md,yml,yaml}'",
    "ci": "biome ci && prettier --check '**/*.{md,yml,yaml}'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:seo": "vitest run tests/seo",
    "test:seo:watch": "vitest tests/seo",
    "analyze": "node scripts/analyze-bundle.mjs",
    "analyze:keep": "node scripts/analyze-bundle.mjs --keep"
  },
  "dependencies": {
    "feed": "5.2.1",
    "framer-motion": "^12.38.0",
    "gl-matrix": "3.4.4",
    "gray-matter": "^4.0.3",
    "hast-util-to-string": "^3.0.1",
    "next": "^16.2.4",
    "nextjs-google-analytics": "^2.3.7",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-icons": "5.6.0",
    "react-markdown": "10.1.0",
    "rehype-highlight": "7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "4.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@next/bundle-analyzer": "^16.2.4",
    "@pandacss/dev": "^1.10.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/hast": "^3.0.4",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "jsdom": "29.1.0",
    "playwright": "^1.59.1",
    "prettier": "3.8.3",
    "schema-dts": "^2.0.0",
    "ts-node": "^10.9.2",
    "typescript": "6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "hono@<4.12.14": ">=4.12.14",
      "@hono/node-server@<1.19.13": ">=1.19.13",
      "diff": ">=5.2.2",
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2",
      "ajv@>=7.0.0 <8.18.0": ">=8.18.0",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "postcss@<8.5.10": ">=8.5.10"
    }
  }
}
