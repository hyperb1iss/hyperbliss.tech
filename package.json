{
  "name": "hyperbliss.tech",
  "version": "2.0.0",
  "description": "Stefanie's Personal Website",
  "author": "Stefanie Jane <stef@hyperbliss.tech>",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "prepare": "panda",
    "dev": "next dev -p 1337",
    "build": "panda && next build",
    "start": "next start -p 1337",
    "lint": "biome check . && prettier --check '**/*.{md,yml,yaml}'",
    "lint:all": "biome check --write --unsafe . && prettier --write '**/*.{md,yml,yaml}'",
    "lint:fix": "biome check --write . && prettier --write '**/*.{md,yml,yaml}'",
    "format": "biome format --write && prettier --write '**/*.{md,yml,yaml}'",
    "format:check": "biome format && prettier --check '**/*.{md,yml,yaml}'",
    "format:md": "prettier --write '**/*.md'",
    "format:yaml": "prettier --write '**/*.{yml,yaml}'",
    "check": "biome check && prettier --check '**/*.{md,yml,yaml}'",
    "ci": "biome ci && prettier --check '**/*.{md,yml,yaml}'",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:seo": "vitest run tests/seo",
    "test:seo:watch": "vitest tests/seo",
    "analyze": "node scripts/analyze-bundle.mjs"
  },
  "dependencies": {
    "feed": "6.0.0",
    "framer-motion": "^12.42.2",
    "gl-matrix": "3.4.4",
    "gray-matter": "^4.0.3",
    "hast-util-to-string": "^3.0.1",
    "just-bash": "^3.1.0",
    "mermaid": "^11.16.0",
    "next": "16.3.0-canary.93",
    "nextjs-google-analytics": "^2.3.7",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-icons": "5.7.0",
    "react-markdown": "10.1.0",
    "rehype-highlight": "7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "4.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@pandacss/dev": "^1.11.4",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/hast": "^3.0.5",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "jsdom": "29.1.1",
    "playwright": "^1.61.1",
    "prettier": "3.9.6",
    "schema-dts": "^2.0.0",
    "typescript": "7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065"
}
