    "rehype-highlight": "7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "4.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@next/bundle-analyzer": "^16.2.2",
    "@pandacss/dev": "^1.9.1",
