{
  "name": "hyperbliss.tech",
  "version": "2.0.0",
  "description": "Stefanie's Personal Website",
  "author": "Stefanie Jane <stef@hyperbliss.tech>",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "prepare": "panda",
    "dev": "next dev",
    "build": "panda && next build",
    "start": "next start",
    "lint": "biome check . && prettier --check '**/*.{md,yml,yaml}'",
    "lint:all": "biome check --write --unsafe . && prettier --write '**/*.{md,yml,yaml}'",
    "lint:fix": "biome check --write . && prettier --write '**/*.{md,yml,yaml}'",
    "format": "biome format --write && prettier --write '**/*.{md,yml,yaml}'",
    "format:check": "biome format && prettier --check '**/*.{md,yml,yaml}'",
    "format:md": "prettier --write '**/*.md'",
    "format:yaml": "prettier --write '**/*.{yml,yaml}'",
    "check": "biome check && prettier --check '**/*.{md,yml,yaml}'",
    "ci": "biome ci && prettier --check '**/*.{md,yml,yaml}'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:seo": "vitest run tests/seo",
    "test:seo:watch": "vitest tests/seo",
    "analyze": "node scripts/analyze-bundle.mjs",
    "analyze:keep": "node scripts/analyze-bundle.mjs --keep"
  },
  "dependencies": {
    "feed": "5.2.1",
    "framer-motion": "^12.40.0",
    "gl-matrix": "3.4.4",
    "gray-matter": "^4.0.3",
    "hast-util-to-string": "^3.0.1",
    "next": "^16.2.6",
    "nextjs-google-analytics": "^2.3.7",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-icons": "5.6.0",
    "react-markdown": "10.1.0",
    "rehype-highlight": "7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "4.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@next/bundle-analyzer": "^16.2.6",
    "@pandacss/dev": "^1.11.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/hast": "^3.0.4",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "jsdom": "29.1.1",
    "playwright": "^1.60.0",
    "prettier": "3.8.3",
    "schema-dts": "^2.0.0",
    "ts-node": "^10.9.2",
    "typescript": "6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1"
}
